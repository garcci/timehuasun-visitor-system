{
  "pages": [
    "pages/index/index",
    "pages/agreement/agreement",
    "pages/apply/apply",
    "pages/status/status",
    "pages/history/history",
    "pages/terms/terms",
    "pages/privacy/privacy"
  ],
  "window": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "时代华鑫访客",
    "navigationBarBackgroundColor": "#1677ff",
    "backgroundColor": "#f8fafc",
    "enablePullDownRefresh": false
  },
  "style": "v2",
  "componentFramework": "glass-easel",
  "lazyCodeLoading": "requiredComponents",
  "__usePrivacyCheck__": true,
  "requiredBackgroundModes": [],
  "optimization": {
    "subPackages": true
  },
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["pages/apply/apply"]
    }
  },
  "permission": {
    "scope.userLocation": {
      "desc": "用于获取位置信息"
    }
  },
  "miniprogramRoot": "miniprogram/",
  "setting": {
    "urlCheck": false,
    "es6": true,
    "enhance": true,
    "postcss": true,
    "minified": true,
    "uglifyFileName": true,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    },
    "condition": false
  }
}
