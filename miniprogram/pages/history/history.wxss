/* pages/history/history.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
}

.scroll { flex: 1; background: #f8fafc; }

.page {
  padding: 32rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  color: #d1d5db;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
  line-height: 1.4;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.5;
  text-align: center;
  max-width: 400rpx;
}

/* 列表项 — 左侧状态色边框 */
.item {
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  background: #fff;
  border-left: 8rpx solid transparent;
  border: 1rpx solid #f1f5f9;
  position: relative;
  transition: all 0.2s ease;
}

.item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.item-pending  { border-left-color: #f59e0b; }
.item-approved { border-left-color: #10b981; }
.item-rejected { border-left-color: #ef4444; }

/* 头部：姓名 + 状态标签 */
.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.item-name-row {
  display: flex;
  align-items: center;
}

.item-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  margin-right: 16rpx;
  line-height: 1.4;
}

.companions-badge {
  font-size: 24rpx;
  color: #3b82f6;
  background: #eff6ff;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #dbeafe;
}

/* 时间行 */
.item-time-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.item-time-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 120rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.item-time-val {
  font-size: 26rpx;
  color: #4b5563;
  flex: 1;
  line-height: 1.5;
}

/* 随行人员区域 */
.companions-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f1f5f9;
}

.companions-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.companion-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.companion-info:last-child {
  margin-bottom: 0;
}

.companion-name {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
  min-width: 100rpx;
}

.companion-detail {
  font-size: 24rpx;
  color: #6b7280;
  flex: 1;
}

.companion-phone {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 底部：提交时间 + 箭头 */
.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid #f1f5f9;
  padding-top: 20rpx;
}

.item-submit-time {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.4;
}

.item-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
  line-height: 1;
}
