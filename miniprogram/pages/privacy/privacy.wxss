// pages/privacy/privacy.wxss
.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: env(safe-area-inset-bottom);
}

.header {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  padding: 40rpx 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  height: calc(100vh - 200rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.text {
  display: block;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.text.highlight {
  font-weight: 600;
  color: #1f2937;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.text.warning {
  background: #fef3c7;
  color: #92400e;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #f59e0b;
  margin: 12rpx 0;
}

.info-card {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin: 12rpx 0;
  border: 1rpx solid #e5e7eb;
}

.info-card.contact {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.info-item {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}
