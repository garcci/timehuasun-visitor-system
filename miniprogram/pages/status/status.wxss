/* pages/status/status.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
}

.scroll { flex: 1; background: #f8fafc; }

.page {
  padding: 32rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 状态横幅 */
.status-banner {
  border-radius: 24rpx;
  padding: 60rpx 32rpx 48rpx;
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.status-pending  { background: linear-gradient(135deg, #eff6ff, #3b82f6); }
.status-approved { background: linear-gradient(135deg, #eff6ff, #3b82f6); }
.status-rejected { background: linear-gradient(135deg, #fef2f2, #fca5a5); }

.status-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10rpx);
}

.status-pending  .status-icon { background: rgba(59, 130, 246, 0.15); }
.status-approved .status-icon { background: rgba(59, 130, 246, 0.15); }
.status-rejected .status-icon { background: rgba(239, 68, 68, 0.15); }

.status-icon-inner {
  font-size: 56rpx;
  font-weight: bold;
  line-height: 1;
}

.status-pending  .status-icon-inner { color: #1d4ed8; }
.status-approved .status-icon-inner { color: #1d4ed8; }
.status-rejected .status-icon-inner { color: #dc2626; }

.status-text {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.status-pending  .status-text { color: #1e40af; }
.status-approved .status-text { color: #1e40af; }
.status-rejected .status-text { color: #991b1b; }

.status-reason {
  font-size: 26rpx;
  color: #991b1b;
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.5;
  max-width: 80%;
}

/* 凭证卡片 */
.credential-card {
  border: 1rpx solid #bfdbfe;
  background: #eff6ff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
}

.credential-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.credential-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e40af;
}

.credential-badge {
  display: flex;
  align-items: center;
  background: #3b82f6;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.credential-badge::before {
  content: '●';
  font-size: 16rpx;
  margin-right: 8rpx;
  color: rgba(255, 255, 255, 0.8);
}

.divider {
  height: 2rpx;
  background: #dbeafe;
  margin: 32rpx 0;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #eff6ff;
}

.info-row.no-border { border-bottom: none; }

.info-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 160rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.info-val {
  font-size: 28rpx;
  color: #1f2937;
  flex: 1;
  word-break: break-all;
  font-weight: 500;
  line-height: 1.5;
}

.time-val {
  font-size: 24rpx;
  color: #4b5563;
  font-weight: normal;
}

/* 随行人员 */
.companion-section-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.companion-row {
  padding: 16rpx 0;
  border-bottom: 2rpx solid #eff6ff;
}

.companion-row:last-child {
  border-bottom: none;
}

.companion-info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.companion-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  line-height: 1.4;
}

.companion-id {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
}

.companion-phone {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.4;
}

/* 二维码区域 */
.qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 16rpx;
}

.qr-hint-top {
  font-size: 28rpx;
  color: #1d4ed8;
  font-weight: 500;
  margin-bottom: 32rpx;
  line-height: 1.4;
  text-align: center;
}

.qr-canvas {
  width: 480rpx;
  height: 480rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.qr-id {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 24rpx;
  letter-spacing: 1rpx;
}

/* 申请详情卡片标题 */
.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8c9099;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 1rpx;
}

/* 演示区域 */
.demo-card {
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
}

.demo-title {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-bottom: 6rpx;
}

.demo-desc {
  font-size: 22rpx;
  color: #ccc;
  display: block;
  margin-bottom: 20rpx;
}

/* 底部操作 */
.footer-btns { margin-top: 8rpx; }
