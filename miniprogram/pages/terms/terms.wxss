// pages/terms/terms.wxss
.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: env(safe-area-inset-bottom);
}

.header {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  padding: 40rpx 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  height: calc(100vh - 200rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.text {
  display: block;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.date {
  font-size: 24rpx;
  color: #9ca3af;
}
