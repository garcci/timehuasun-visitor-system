/* pages/index/index.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(160deg, #f0f9ff 0%, #f8fafc 45%);
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 80rpx 40rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 80rpx;
}

.hero-logo {
  width: 640rpx;
  height: 640rpx;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  letter-spacing: 0;
  text-align: center;
  line-height: 1.3;
}

.hero-sub {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  max-width: 480rpx;
  line-height: 1.6;
}

.actions { width: 100%; }

.notice {
  display: flex;
  align-items: flex-start;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  color: #92400e;
  font-size: 26rpx;
  line-height: 1.5;
}

.notice::before {
  content: '⚠';
  margin-right: 16rpx;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  padding: 16rpx 0;
}

.link {
  font-size: 24rpx;
  color: #1677ff;
  padding: 8rpx 12rpx;
}

.divider {
  font-size: 24rpx;
  color: #d1d5db;
  margin: 0 4rpx;
}

/* 协议弹窗 */
.agreement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.modal-body {
  margin-bottom: 40rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  display: block;
  margin-bottom: 32rpx;
}

.check-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.check-item {
  display: flex;
  align-items: center;
}

.check-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.check-text {
  font-size: 28rpx;
  color: #4b5563;
  margin-left: 16rpx;
}

.check-link {
  font-size: 28rpx;
  color: #1677ff;
  margin-left: 8rpx;
}

.modal-footer {
  padding-top: 16rpx;
}

.btn-agree {
  width: 100%;
  height: 96rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-agree.disabled {
  background: #cbd5e1;
  color: #94a3b8;
}

.btn-agree::after {
  border: none;
}
