<!--pages/index/index.wxml-->
<view class="page">
  <view class="hero">
    <image class="hero-logo" src="/logo.png" mode="aspectFit"></image>
    <text class="hero-title">访客管理系统</text>
    <text class="hero-sub">欢迎使用，请发起进厂申请</text>
  </view>

  <view class="actions">
    <view wx:if="{{pendingCount > 0}}" class="notice">
      <text>您有 {{pendingCount}} 条申请待审批</text>
    </view>
    <button class="btn-primary" bindtap="onApply">发起申请</button>
    <button class="btn-secondary" bindtap="onHistory">历史记录</button>
  </view>

  <view class="footer-links">
    <text class="link" bindtap="onTerms">《用户服务协议》</text>
    <text class="divider">|</text>
    <text class="link" bindtap="onPrivacy">《隐私政策》</text>
  </view>
</view>

<!-- 协议同意弹窗 -->
<view class="agreement-modal" wx:if="{{showAgreementModal}}">
  <view class="modal-mask" bindtap="onAgree"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">服务协议与隐私政策</text>
    </view>
    <view class="modal-body">
      <text class="modal-desc">欢迎使用访客管理系统，在使用前请您仔细阅读并同意以下协议：</text>
      <view class="check-list">
        <view class="check-item">
          <checkbox-group bindchange="onPrivacyCheck">
            <label class="check-label">
              <checkbox checked="{{agreedPrivacy}}" />
              <text class="check-text">我已阅读并同意</text>
              <text class="check-link" bindtap="onViewPrivacy">《隐私政策》</text>
            </label>
          </checkbox-group>
        </view>
        <view class="check-item">
          <checkbox-group bindchange="onTermsCheck">
            <label class="check-label">
              <checkbox checked="{{agreedTerms}}" />
              <text class="check-text">我已阅读并同意</text>
              <text class="check-link" bindtap="onViewTerms">《用户服务协议》</text>
            </label>
          </checkbox-group>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-agree {{agreedPrivacy && agreedTerms ? '' : 'disabled'}}" bindtap="onAgree">
        同意并继续
      </button>
    </view>
  </view>
</view>
