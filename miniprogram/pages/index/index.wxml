<!--pages/index/index.wxml-->
<view class="page">
  <view class="hero">
    <image class="hero-logo" src="/logo.png" mode="aspectFit"></image>
    <text class="hero-title">访客管理系统</text>
    <text class="hero-sub">欢迎使用，请发起进厂申请</text>
  </view>

  <view class="actions">
    <view wx:if="{{pendingCount > 0}}" class="notice">
      <text>您有 {{pendingCount}} 条申请待审批</text>
    </view>
    <button class="btn-primary" bindtap="onApply">发起申请</button>
    <button class="btn-secondary" bindtap="onHistory">历史记录</button>
  </view>

  <view class="footer-links">
    <text class="link" bindtap="onTerms">《用户服务协议》</text>
    <text class="divider">|</text>
    <text class="link" bindtap="onPrivacy">《隐私政策》</text>
  </view>
</view>
