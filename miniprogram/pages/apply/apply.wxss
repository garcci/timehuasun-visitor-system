/* pages/apply/apply.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
}

.scroll { flex: 1; background: #f8fafc; }

.page {
  padding: 32rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f1f5f9;
}

/* 卡片标题行 */
.card-hdr {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.icon-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.icon-badge.green  { background: #10b981; }
.icon-badge.orange { background: #f59e0b; }

.card-ttl {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 常用被访人 */
.frequent-hosts-section {
  margin-bottom: 32rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e2e8f0;
}

.frequent-hosts-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.frequent-hosts-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.frequent-hosts-toggle {
  font-size: 24rpx;
  color: #3b82f6;
}

.frequent-hosts-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.frequent-host-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.frequent-host-item:active {
  background: #eff6ff;
  border-color: #3b82f6;
}

.frequent-host-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.frequent-host-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.frequent-host-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.frequent-host-phone {
  font-size: 24rpx;
  color: #6b7280;
}

.frequent-host-select {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: #eff6ff;
  border-radius: 24rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #f1f5f9;
  margin-bottom: 32rpx;
}

/* 字段块 */
.field {
  margin-bottom: 32rpx;
  position: relative; /* 为历史记录选择器提供定位上下文 */
}

.field.last {
  margin-bottom: 8rpx;
}

.field-lbl {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 20rpx;
  display: block;
  line-height: 1.4;
}

.req { color: #ef4444; }

/* 输入框带清空按钮 */
.input-with-clear {
  position: relative;
  display: flex;
  align-items: center;
}

.input-with-clear .field-inp {
  padding-right: 60rpx;
}

.clear-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  background: #d1d5db;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.clear-btn:active {
  background: #9ca3af;
}

/* 错误抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-4rpx); }
  20%, 40%, 60%, 80% { transform: translateX(4rpx); }
}

.field.error {
  animation: shake 0.4s ease-in-out;
}

.field.error .field-inp,
.field.error .field-picker,
.field.error .time-picker {
  border-color: #ef4444;
  background: #fef2f2;
}

/* 完成标记 */
.field.completed .field-lbl::after {
  content: ' ✓';
  color: #10b981;
}

/* 输入框 */
.field-inp {
  width: 100%;
  height: 69rpx; /* 92rpx * 0.75 = 69rpx */
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.field-inp:focus {
  border-color: #3b82f6;
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(59, 130, 246, 0.1);
}

.inp-ph { color: #9ca3af; }

/* 下拉选择器 */
.field-picker {
  width: 100%;
  height: 69rpx; /* 92rpx * 0.75 = 69rpx */
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.field-picker:active {
  border-color: #3b82f6;
  background: #fff;
}

.field-picker.picker-ph { color: #9ca3af; }

.picker-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  line-height: 1;
}

/* 时间选择行 */
.time-row {
  display: flex;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
  height: 69rpx; /* 与输入框持平 */
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  font-size: 30rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  transition: all 0.2s ease;
}

.time-picker:active {
  border-color: #3b82f6;
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(59, 130, 246, 0.1);
}

.time-picker.picker-ph { color: #9ca3af; }

/* 文本域 */
.field-ta {
  width: 100%;
  min-height: 180rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.2s ease;
}

.field-ta:focus {
  border-color: #3b82f6;
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(59, 130, 246, 0.1);
}

/* 错误提示 */
.err {
  font-size: 24rpx;
  color: #ef4444;
  padding: 16rpx 0 0;
  display: block;
  line-height: 1.5;
}

/* 输入框容器（带图标） */
.input-with-icon {
  position: relative;
  display: flex;
  align-items: center;
}

.input-with-icon .field-inp {
  padding-right: 80rpx; /* 为图标留出空间 */
}

/* 验证状态图标 */
.validate-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

/* 输入框容器（带标签） */
.input-with-tag {
  position: relative;
  display: flex;
  align-items: center;
}

/* 自动填充标签 */
.auto-fill-tag {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #07c160;
  padding: 4rpx 12rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 6rpx;
  z-index: 10;
}

/* 自动填充的输入框样式 */
.auto-filled {
  background-color: #f5f5f5 !important;
  color: #333 !important;
}

/* 验证中的输入框 */
.validating {
  border-color: #f59e0b !important;
}

/* 验证成功的输入框 */
.validated-success {
  border-color: #07c160 !important;
  background-color: rgba(7, 193, 96, 0.05) !important;
}

/* 成功提示 */
.success-tip {
  font-size: 24rpx;
  color: #10b981;
  padding: 16rpx 0 0;
  display: block;
  line-height: 1.5;
}

/* 字段提示 */
.field-hint {
  font-size: 24rpx;
  color: #9ca3af;
  padding: 8rpx 0 0;
  display: block;
  line-height: 1.5;
}

/* 历史记录选择器 */
.history-picker {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  max-height: 300rpx;
  overflow-y: auto;
  margin-top: 8rpx;
}

.history-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  border-bottom: 1rpx solid #f3f4f6;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #f3f4f6;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.25);
  transition: all 0.2s ease;
}

.submit-btn:active {
  background: #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.35);
}

.submit-btn::after { border: none; }

/* 随行人员样式 */
.companion-count {
  margin-left: auto;
  font-size: 26rpx;
  color: #10b981;
  font-weight: 500;
  background: #d1fae5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.companion-add-section {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  border: 2rpx dashed #cbd5e1;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.title-icon {
  width: 40rpx;
  height: 40rpx;
  background: #10b981;
  color: white;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.add-companion-btn {
  width: 100%;
  height: 88rpx;
  background: #10b981;
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.add-companion-btn.disabled {
  background: #d1d5db;
  color: #9ca3af;
}

.add-companion-btn:not(.disabled):active {
  background: #0da271;
}

.add-companion-btn::after { border: none; }

.companion-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 12rpx;
  background: #e0f2fe;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #0369a1;
}

.companions-list {
  margin-bottom: 20rpx;
}

.companion-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.companion-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.companion-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.companion-phone {
  display: block;
  font-size: 26rpx;
  color: #3b82f6;
  margin-bottom: 8rpx;
}

.companion-idcard {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.4;
}

.remove-btn {
  width: 48rpx !important;
  height: 48rpx !important;
  min-width: 48rpx !important;
  max-width: 48rpx !important;
  border-radius: 24rpx;
  background: #fee2e2;
  border: none;
  margin-left: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 !important;
  box-sizing: border-box;
}

.remove-icon {
  font-size: 28rpx;
  color: #dc2626;
  font-weight: bold;
  line-height: 1;
}

.remove-btn:active {
  background: #fecaca;
  transform: scale(0.95);
}

.remove-btn::after { border: none; }
