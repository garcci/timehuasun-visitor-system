/* pages/agreement/agreement.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f1f5f9;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.content-scroll {
  flex: 1;
  height: 0;
  padding: 24rpx;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 头部区域 */
.header-section {
  text-align: center;
  padding: 16rpx 0;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.agreement-subtitle {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.intro-card {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border: 1rpx solid #bfdbfe;
}

.intro-text {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.7;
}

.intro-text.highlight {
  color: #1d4ed8;
  font-weight: 600;
}

/* 章节卡片 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-number.urgent {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  flex: 1;
}

.section-title-text.urgent {
  color: #dc2626;
}

/* 列表项 */
.list-item {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.list-item:last-child {
  margin-bottom: 0;
}

.list-item.warning {
  background: #fef3c7;
  padding: 16rpx;
  border-radius: 10rpx;
  color: #92400e;
  font-weight: 500;
}

/* 紧急卡片 */
.special-card {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
  border: 1rpx solid #fecaca;
}

.urgent-body {
  font-size: 28rpx;
  color: #991b1b;
  line-height: 1.8;
  font-weight: 500;
}

/* 签署确认区 */
.sign-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sign-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.sign-text {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.7;
}

.agreement-checks {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
  border: 1rpx solid #e5e7eb;
}

.check-item {
  margin-bottom: 16rpx;
}

.check-item:last-child {
  margin-bottom: 0;
}

.check-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  transform: scale(0.8);
}

.check-text {
  font-size: 26rpx;
  color: #4b5563;
}

.check-link {
  font-size: 26rpx;
  color: #1677ff;
  text-decoration: underline;
  margin-left: 4rpx;
}

/* 底部签署区 */
.footer {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: #e2e8f0;
  border-radius: 3rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 3rpx;
  transition: width 1s linear;
}

.btn-sign {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
}

.btn-sign:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
}

.btn-sign::after { border: none; }

.btn-sign-disabled {
  background: #cbd5e1;
  color: #94a3b8;
  box-shadow: none;
  transform: none;
}

.btn-signed {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}
