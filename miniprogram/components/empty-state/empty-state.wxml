<!-- components/empty-state/empty-state.wxml -->
<view class="empty-state" wx:if="{{show}}">
  <view class="empty-icon" wx:if="{{!icon}}">📋</view>
  <image class="empty-icon-img" wx:else src="{{icon}}" mode="aspectFit"></image>
  <text class="empty-title">{{title || '暂无数据'}}</text>
  <text class="empty-desc" wx:if="{{desc}}">{{desc}}</text>
  <button class="empty-btn" wx:if="{{showBtn}}" bindtap="onBtnTap">{{btnText || '去操作'}}</button>
</view>
