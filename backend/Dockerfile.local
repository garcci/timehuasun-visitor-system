FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache bash curl jq vim

COPY package*.json ./

# 在线安装依赖
RUN npm install --production

COPY . .

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:3000/health || exit 1

CMD ["node", "src/index.js"]
