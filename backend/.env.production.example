# 生产环境变量配置示例
# 复制此文件为 .env 并修改为实际值

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=8020

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=visitor_user
DB_PASSWORD=YourStrongPassword@123
DB_NAME=visitor_system

# ==================== OA 系统配置 ====================
# 外网可访问的 OA 系统地址（必须 HTTPS）
OA_BASE_URL=https://oa.your-company.com

# Basic Auth 认证信息（从 OA 系统获取）
OA_AUTHORIZATION=Basic YXBpOkdkZnZ0RW5jQ1JVMTRYdg==

# API 密钥（与 OA 系统约定）
OA_API_KEY=your-production-api-key-here
OA_API_SECRET=your-production-api-secret-here

# OA 审批流程类型 ID（从 OA 系统获取）
OA_FLOW_TYPE_ID=visitor_approval_flow_prod_001

# OA 回调验证 Token（自定义强密码）
OA_CALLBACK_TOKEN=your-super-secret-callback-token-min-32-chars

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YourRedisPassword@123
REDIS_DB=0

# ==================== 微信小程序配置 ====================
# 从微信公众平台获取
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=your-wechat-app-secret-here

# ==================== JWT 配置 ====================
# 必须使用强密码（至少 32 个字符）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_DIR=/var/log/visitor-system

# ==================== 服务器配置 ====================
# 外网访问地址（用于生成二维码等）
SERVER_PUBLIC_URL=https://api.your-domain.com

# ==================== 安全配置 ====================
# 请求频率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=60

# 文件上传大小限制（MB）
MAX_UPLOAD_SIZE_MB=10

# CORS 允许的域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==================== 邮件通知配置（可选）====================
MAIL_ENABLED=false
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USER=your-email@qq.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=访客系统<noreply@your-domain.com>

# ==================== 短信通知配置（可选）====================
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-sms-access-key
SMS_ACCESS_SECRET=your-sms-access-secret
SMS_SIGN_NAME=您的公司名

# ==================== 监控告警配置（可选）====================
MONITORING_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/1234567
ALERT_EMAIL=admin@your-domain.com

# ==================== 性能优化配置 ====================
# 缓存过期时间（秒）
CACHE_TTL_DEFAULT=300
CACHE_TTL_USER_INFO=600
CACHE_TTL_PHONE_QUERY=300

# 熔断器配置
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ==================== 调试配置（生产环境禁用）====================
DEBUG_MODE=false
ENABLE_DETAILED_LOGS=false
